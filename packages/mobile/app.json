{
  "expo": {
    "name": "LawnBot",
    "slug": "lawnbot",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "lawnbot",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lawnbot.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#030712",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.lawnbot.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
